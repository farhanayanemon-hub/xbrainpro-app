modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mobile Game"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 NODE_ENV=development pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20677 BASE_PATH=/ pnpm --filter @workspace/xbrainpro-web run dev"
waitForPort = 20677

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Mobile Game"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=25192 BASE_PATH=/xbrainpro-mobile/ pnpm --filter @workspace/xbrainpro-mobile run dev"
waitForPort = 25192

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
OPENROUTER_MODEL = "openai/gpt-oss-20b:free"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 20677
externalPort = 80

[[ports]]
localPort = 25192
externalPort = 3000
